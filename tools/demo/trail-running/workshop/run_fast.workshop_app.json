          "position": {
            "x": 5,
            "y": 1,
            "width": 7,
            "height": 2
          },
          "props": {
            "label": "Estimated Effort for Boulder Creek Path East",
            "layout_style": "card",
            "direction": "horizontal",
            "template": "stacked",
            "metric_size": "regular",
            "metrics": [
              {
                "id": "estimated-pace",
