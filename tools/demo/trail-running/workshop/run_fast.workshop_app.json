    {
      "id": "custom-gpx-upload-page",
      "name": "Upload GPX",
      "path": "/upload",
      "description": "Upload a GPX file, parse it into a Trail object, and create an effort estimate.",
      "visible": true,
      "layout": {
        "kind": "grid",
        "columns": 12,
        "gap": "16px",
        "max_width": "1180px"
      },
      "widgets": [
        {
          "id": "custom-gpx-upload",
          "widget_type": "media_uploader",
          "title": "Custom GPX Upload",
          "description": "Parse a GPX file into the Trail object type and refresh the app.",
          "position": {
            "x": 0,
            "y": 0,
            "width": 4,
            "height": 3
          },
          "props": {
            "upload_mode": "gpx_trail",
            "text": "Upload GPX",
            "intent": "success",
            "allowed_extensions": ".gpx,application/gpx+xml",
            "multi_file": false,
            "trail_object_type_id": "Trail",
            "estimate_object_type_id": "TrailEffortEstimate",
            "estimate_function_package_id": "estimateTrailEffort"
          },
          "binding": null,
          "events": [
            {
              "id": "refresh-after-custom-gpx-upload",
              "trigger": "on_upload",
              "action": "refresh",
              "kind": "refresh",
              "label": "Refresh after GPX upload",
              "config": {}
            }
          ],
          "actions": [],
          "children": []
        },
        {
          "id": "uploaded-trails-table",
          "widget_type": "object_table",
          "title": "Uploaded Trails",
          "description": "Trail objects after GPX upload.",
          "position": {
            "x": 4,
            "y": 0,
            "width": 8,
            "height": 4
          },
          "props": {
            "source_variable_id": "trail-set",
            "columns": [
