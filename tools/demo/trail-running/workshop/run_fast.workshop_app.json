                  "trail_name",
                  "distance_miles",
                  "elevation_gain_ft",
                  "start_lat",
                  "start_lon",
                  "trailhead_geopoint"
                ]
              }
            ],
            "properties": [
              "trail_name",
              "distance_miles",
              "elevation_gain_ft",
              "start_lat",
              "start_lon",
              "trailhead_geopoint"
            ],
            "number_of_columns": 1,
