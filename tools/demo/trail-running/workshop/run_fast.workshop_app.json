              "distance_miles",
              "elevation_gain_ft",
              "start_lat",
              "start_lon"
            ],
            "default_sort_property": "trail_name",
            "default_sort_direction": "asc",
            "row_height_lines": 1,
            "wrap_values": false,
            "multi_select": false,
            "enable_inline_edit": false
          },
          "binding": null,
          "events": [],
          "actions": [],
          "children": []
        },
        {
          "id": "uploaded-effort-estimates",
          "widget_type": "object_table",
          "title": "Uploaded Effort Estimates",
          "description": "Effort estimates created from uploaded GPX trails.",
          "position": {
            "x": 0,
            "y": 4,
            "width": 12,
            "height": 3
          },
          "props": {
            "source_variable_id": "trail-estimates",
            "columns": [
