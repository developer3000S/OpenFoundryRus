            "x": 0,
            "y": 0,
            "width": 12,
            "height": 1
          },
          "props": {
            "source_variable_id": "selected-trail-detail",
            "title_property": "trail_name",
            "show_icon": true,
            "empty_text": "No trail selected"
          },
          "binding": null,
          "events": [],
          "actions": [],
          "children": []
        },
        {
          "id": "selected-trail-properties",
          "widget_type": "property_list",
          "title": "Selected Trail Details",
