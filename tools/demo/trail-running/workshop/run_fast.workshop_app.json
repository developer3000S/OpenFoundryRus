{
  "id": "trail-running-run-fast",
  "name": "Run Fast",
  "slug": "run-fast",
  "description": "Published Workshop acceptance app for the synthetic Trail Running demo.",
  "status": "published",
  "pages": [
    {
      "id": "trail-overview",
      "name": "Trail Overview",
      "path": "/",
      "description": "Trail list, filters, effort chart, and current weather metrics.",
      "visible": true,
      "layout": {
        "kind": "grid",
        "columns": 12,
        "gap": "16px",
        "max_width": "1180px"
      },
      "widgets": [
        {
          "id": "trail-filters",
          "widget_type": "filter_list",
          "title": "Filters",
          "description": "Filter trail objects for the overview widgets.",
          "position": {
            "x": 0,
            "y": 0,
            "width": 3,
            "height": 2
          },
          "props": {
            "source_variable_id": "trail-set",
            "output_variable_id": "trail-filter",
            "layout": "pills",
            "allow_add_remove": true,
            "filters": [
              {
                "id": "trail-name-filter",
                "property_name": "trail_name",
                "display_name": "Trail Name",
                "component": "multi_select",
                "values": []
              }
            ]
          },
          "binding": null,
          "events": [],
          "actions": [],
          "children": []
        },
        {
          "id": "trail-table",
          "widget_type": "object_table",
          "title": "Trail List",
          "description": "Selectable Trail object table.",
          "position": {
            "x": 0,
            "y": 2,
            "width": 7,
            "height": 4
          },
          "props": {
            "source_variable_id": "filtered-trails",
            "columns": [
              "trail_name",
              "distance_miles",
              "elevation_gain_ft",
              "start_lat",
              "start_lon"
            ],
            "default_sort_property": "trail_name",
            "default_sort_direction": "asc",
            "row_height_lines": 1,
            "wrap_values": false,
            "multi_select": true,
            "active_object_variable_id": "trail-active",
            "selected_object_set_variable_id": "trail-selected",
            "enable_inline_edit": false
          },
          "binding": null,
          "events": [
            {
              "id": "open-trail-detail",
              "trigger": "select",
              "kind": "navigate",
              "target": "/trail",
              "label": "Open trail detail"
            }
          ],
          "actions": [],
          "children": []
        },
        {
          "id": "trail-distance-chart",
          "widget_type": "chart_xy",
          "title": "Trail Distances",
          "description": "Distance bars with estimated pace overlay.",
          "position": {
            "x": 7,
            "y": 0,
            "width": 5,
            "height": 4
          },
          "props": {
            "layers": [
              {
                "id": "trail-distance-bars",
                "title": "Trail distance",
                "data_input": "object_set",
                "source_variable_id": "trail-estimates",
                "object_type_id": "TrailEffortEstimate",
                "layer_type": "bar",
                "show_labels": true,
                "x_property": "trail_name",
                "series_metric": "avg",
                "series_property": "distance_miles"
              },
              {
                "id": "estimated-pace-line",
                "title": "Estimated pace",
                "data_input": "object_set",
                "source_variable_id": "trail-estimates",
                "object_type_id": "TrailEffortEstimate",
                "layer_type": "line",
                "show_labels": true,
                "x_property": "trail_name",
                "series_metric": "avg",
                "series_property": "estimated_pace_min_per_mile"
              }
            ],
            "bar_orientation": "vertical",
            "show_legend": true,
            "show_tooltips": true,
            "output_filter_variable_id": "chart-trail-filter",
            "selected_object_set_variable_id": "chart-selected-estimates"
          },
          "binding": null,
          "events": [],
          "actions": [],
          "children": []
        },
        {
          "id": "weather-metrics",
          "widget_type": "metric",
          "title": "Weather Conditions",
          "description": "Current weather snapshot for the default selected trail.",
          "position": {
            "x": 7,
            "y": 4,
            "width": 5,
            "height": 2
          },
          "props": {
            "label": "Weather Conditions in Boulder, CO",
            "layout_style": "card",
            "direction": "horizontal",
            "template": "stacked",
            "metric_size": "regular",
            "metrics": [
              {
                "id": "temperature",
                "label": "Current Temperature",
                "value_type": "number",
                "variable_id": "weather-temperature",
                "format": {
                  "kind": "unit",
                  "precision": 1,
                  "unit": "Fahrenheit"
                },
                "conditional_formatting": [
                  {
                    "operator": "gte",
                    "value": 80,
                    "tone": "warning"
                  }
                ]
              },
              {
                "id": "wind-speed",
                "label": "Current Windspeed",
                "value_type": "number",
                "variable_id": "weather-wind-speed",
                "format": {
                  "kind": "unit",
                  "precision": 1,
                  "unit": "mph"
                }
              },
              {
                "id": "humidity",
                "label": "Current Humidity",
                "value_type": "number",
                "variable_id": "weather-humidity",
                "format": {
                  "kind": "unit",
                  "precision": 0,
                  "suffix": "%"
                }
              }
            ]
          },
          "binding": null,
          "events": [],
          "actions": [],
          "children": []
        },
        {
          "id": "weather-action",
          "widget_type": "button_group",
          "title": "Weather Actions",
          "description": "Fetch weather for the selected trail.",
          "position": {
            "x": 0,
            "y": 6,
            "width": 12,
            "height": 1
          },
          "props": {
            "orientation": "horizontal",
            "fill_horizontal": false,
            "buttons": [
              {
                "id": "fetch-weather",
                "label": "Get Weather",
                "on_click_kind": "action",
                "action_type_id": "FetchTrailWeather",
                "default_layout": "form",
                "switch_layout": false,
                "conditional_visibility": false,
                "parameter_defaults": {
                  "trail_id": {
                    "kind": "static",
                    "static_value": "boulder-creek-path",
                    "visibility": "visible"
                  },
                  "trail_name": {
                    "kind": "static",
                    "static_value": "Boulder Creek Path East",
                    "visibility": "visible"
                  },
                  "latitude": {
                    "kind": "static",
                    "static_value": 40.0153,
                    "visibility": "visible"
                  },
                  "longitude": {
                    "kind": "static",
                    "static_value": -105.289,
                    "visibility": "visible"
                  },
                  "trailhead_geopoint": {
                    "kind": "static",
                    "static_value": "40.0153,-105.289",
                    "visibility": "disabled"
                  }
                }
              }
            ]
          },
          "binding": null,
          "events": [],
          "actions": [],
          "children": []
        }
      ]
    },
    {
      "id": "trail-map-page",
      "name": "Trail Map",
      "path": "/map",
      "description": "Map with trailheads, trail routes, coffee shops, and trail-to-coffee lines.",
      "visible": true,
      "layout": {
        "kind": "grid",
        "columns": 12,
        "gap": "16px",
        "max_width": "1180px"
      },
      "widgets": [
        {
          "id": "trail-coffee-map",
          "widget_type": "map",
          "title": "Trail Starts & Coffee Shops",
          "description": "MapLibre map for trailheads, routes, cafes, and nearest-coffee links.",
          "position": {
            "x": 0,
            "y": 0,
            "width": 12,
            "height": 6
          },
          "props": {
            "base_layer_kind": "blank",
            "center_lat": 39.998,
            "center_lon": -105.289,
            "zoom": 12,
            "output_variable_id": "map-active-trail",
            "output_object_set_variable_id": "map-selected-trails",
            "layers": [
              {
                "id": "trail-starts",
                "title": "Trail Starts",
                "source": "object_set",
                "source_variable_id": "trail-set",
                "geometry_type": "point",
                "latitude_field": "start_lat",
                "longitude_field": "start_lon",
                "label_field": "trail_name",
                "color": "#7c3aed",
                "radius": 7,
                "cluster_enabled": true,
                "cluster_radius": 72,
                "cluster_max_zoom": 9,
                "visible": true
              },
              {
                "id": "trail-routes",
                "title": "Trail Routes",
                "source": "object_set",
                "source_variable_id": "trail-set",
                "geometry_type": "line",
                "geometry_field": "route_geojson",
                "label_field": "trail_name",
                "color": "#c2410c",
                "line_width": 4,
                "visible": true
              },
              {
                "id": "coffee-shops",
                "title": "Coffee Shops",
                "source": "object_set",
                "source_variable_id": "coffee-set",
                "geometry_type": "point",
                "latitude_field": "latitude",
                "longitude_field": "longitude",
                "label_field": "name",
                "color": "#0f766e",
                "radius": 6,
                "visible": true
              },
              {
                "id": "trail-coffee-lines",
                "title": "Distance to Coffee",
                "source": "object_set",
                "source_variable_id": "trail-coffee-recommendations",
                "geometry_type": "line",
                "geometry_field": "line_geojson",
                "label_field": "coffee_shop_name",
                "color": "#d97706",
                "line_width": 2,
                "visible": true
              }
            ],
            "overlay_layers": []
          },
          "binding": null,
          "events": [],
          "actions": [],
          "children": []
        },
        {
          "id": "nearest-coffee-table",
          "widget_type": "object_table",
          "title": "Nearest Coffee Shops",
          "description": "Nearest cafes ranked by Haversine distance from each trailhead.",
          "position": {
            "x": 0,
            "y": 6,
            "width": 12,
            "height": 3
          },
          "props": {
            "source_variable_id": "trail-coffee-recommendations",
            "columns": [
              "trail_name",
              "coffee_shop_name",
              "rank",
              "distance_miles",
              "coffee_rating"
            ],
            "default_sort_property": "rank",
            "default_sort_direction": "asc",
            "row_height_lines": 1,
            "wrap_values": false,
            "multi_select": false,
            "enable_inline_edit": false
          },
          "binding": null,
          "events": [],
          "actions": [],
          "children": []
        }
      ]
    },
    {
      "id": "trail-detail-page",
      "name": "Trail Detail",
      "path": "/trail",
      "description": "Selected trail properties, estimated effort, and nearest coffee recommendations.",
      "visible": true,
      "layout": {
        "kind": "grid",
        "columns": 12,
        "gap": "16px",
        "max_width": "1180px"
      },
      "widgets": [
        {
          "id": "selected-trail-title",
          "widget_type": "object_set_title",
