          },
          "binding": null,
          "events": [],
          "actions": [],
          "children": []
        },
        {
          "id": "selected-coffee-table",
          "widget_type": "object_table",
          "title": "Coffee Recommendations",
          "description": "Nearest coffee shops for the selected/default trail.",
          "position": {
            "x": 0,
            "y": 5,
            "width": 12,
            "height": 3
          },
          "props": {
            "source_variable_id": "selected-trail-coffee",
            "columns": [
              "coffee_shop_name",
              "rank",
              "distance_miles",
              "coffee_neighborhood",
              "coffee_rating"
            ],
            "default_sort_property": "rank",
            "default_sort_direction": "asc",
            "row_height_lines": 1,
