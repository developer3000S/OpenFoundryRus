            "value_layout": "below",
            "enable_value_wrapping": true
          },
          "binding": null,
          "events": [],
          "actions": [],
          "children": []
        },
        {
          "id": "effort-metrics",
          "widget_type": "metric",
          "title": "Effort Estimate",
