        "source": "from pathlib import Path\nimport importlib.util\n\npath = Path('tools/demo/trail-running/pipelines/coffee_recommendations.py')\nif not path.exists():\n    path = Path('pipelines/coffee_recommendations.py')\nspec = importlib.util.spec_from_file_location('coffee_recommendations', path)\nmodule = importlib.util.module_from_spec(spec)\nspec.loader.exec_module(module)\nresult_rows = [module.build_link_row(row) for row in input_rows]\n"
