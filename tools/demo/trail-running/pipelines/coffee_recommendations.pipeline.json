      "depends_on": [
        "trail_rows_input",
        "coffee_shop_rows_input"
      ],
      "config": {
        "_geo_join": {
          "mode": "nearest",
          "join_type": "left",
          "left_lat_column": "start_lat",
          "left_lon_column": "start_lon",
          "right_lat_column": "latitude",
          "right_lon_column": "longitude",
          "unit": "miles",
          "k": 3,
          "distance_column": "distance_miles",
          "rank_column": "rank",
          "right_prefix": "coffee_",
          "auto_select_left": true,
          "right_columns": [
            "coffee_shop_id",
            "name",
            "latitude",
            "longitude",
            "neighborhood",
            "rating",
            "walkup_window"
          ],
          "max_left_rows": 500,
          "max_right_rows": 1000,
          "max_candidate_pairs": 100000
        },
        "postprocess": {
          "source_file": "pipelines/coffee_recommendations.py",
          "entrypoint": "build_coffee_recommendations",
          "nearest_n": 3,
          "model": "haversine_trailhead_to_cafe_v1"
        }
