{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}
